---
/**
 * Header.astro — Navegación principal Life Focus
 * Dark mode por defecto, logo adaptativo
 * Nav: Inicio, Nosotros, Servicios (dropdown), Blog, Contacto
 */

interface Props {
  currentPage?: string;
}

const { currentPage = '/' } = Astro.props;

const services = [
  { label: 'WaaS — Web as a Service', href: '/servicios/waas' },
  { label: 'Diseño Web Premium', href: '/servicios/diseno-web' },
  { label: 'Google Ads', href: '/servicios/google-ads' },
  { label: 'Meta Ads', href: '/servicios/meta-ads' },
  { label: 'Redes Sociales', href: '/servicios/redes-sociales' },
];

const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contacto' },
];
---

<header class="site-header" id="site-header">
  <div class="site-header__inner">
    <!-- Logo -->
    <a class="site-header__logo" href="/" aria-label="Life Focus — Inicio">
      <img
        src="/logo-dark.png"
        alt="Life Focus"
        class="site-header__logo-img site-header__logo-img--dark"
        width="160"
        height="40"
      />
      <img
        src="/logo-light.png"
        alt="Life Focus"
        class="site-header__logo-img site-header__logo-img--light"
        width="160"
        height="40"
      />
    </a>

    <!-- Nav desktop -->
    <nav class="site-header__nav" aria-label="Navegación principal">
      <ul class="site-header__nav-list" role="list">
        {navItems.slice(0, 2).map(item => (
          <li>
            <a
              class={`site-header__nav-link${currentPage === item.href ? ' site-header__nav-link--active' : ''}`}
              href={item.href}
            >
              {item.label}
            </a>
          </li>
        ))}

        <!-- Servicios con dropdown -->
        <li class="site-header__nav-item--dropdown">
          <button
            class={`site-header__nav-link site-header__dropdown-trigger${currentPage?.startsWith('/servicios') ? ' site-header__nav-link--active' : ''}`}
            aria-haspopup="true"
            aria-expanded="false"
            type="button"
          >
            Servicios
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>

          <ul class="site-header__dropdown" role="list">
            {services.map(s => (
              <li>
                <a class="site-header__dropdown-link" href={s.href}>{s.label}</a>
              </li>
            ))}
          </ul>
        </li>

        {navItems.slice(2).map(item => (
          <li>
            <a
              class={`site-header__nav-link${currentPage === item.href ? ' site-header__nav-link--active' : ''}`}
              href={item.href}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Acciones -->
    <div class="site-header__actions">
      <!-- Toggle dark/light -->
      <button
        class="site-header__theme-toggle"
        id="theme-toggle"
        type="button"
        aria-label="Cambiar tema"
      >
        <svg class="site-header__theme-icon site-header__theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="site-header__theme-icon site-header__theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a class="btn btn--primary btn--sm site-header__cta" href="/contacto">
        Agenda tu llamada
      </a>

      <!-- Hamburger mobile -->
      <button
        class="site-header__hamburger"
        id="nav-toggle"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav class="site-header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      <li><a class="site-header__mobile-link" href="/">Inicio</a></li>
      <li><a class="site-header__mobile-link" href="/nosotros">Nosotros</a></li>
      <li>
        <span class="site-header__mobile-group-label">Servicios</span>
        <ul class="site-header__mobile-submenu" role="list">
          {services.map(s => (
            <li><a class="site-header__mobile-sublink" href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </li>
      <li><a class="site-header__mobile-link" href="/blog">Blog</a></li>
      <li><a class="site-header__mobile-link" href="/contacto">Contacto</a></li>
      <li>
        <a class="btn btn--primary" href="/contacto" style="inline-size:100%;justify-content:center;margin-block-start:0.5rem;">
          Agenda tu llamada
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  /* ── Header ── */
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 100;
    background-color: rgba(13,13,13,0.85);
    backdrop-filter: blur(16px);
    border-block-end: 1px solid var(--color-border);
    transition: background var(--transition-base);
  }

  [data-theme="light"] .site-header {
    background-color: rgba(255,255,255,0.9);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    max-inline-size: var(--width-content);
    margin-inline: auto;
    padding-inline: var(--spacing-gutter);
    padding-block: 1rem;
  }

  /* Logo */
  .site-header__logo { display: flex; align-items: center; flex-shrink: 0; }
  .site-header__logo-img { block-size: 36px; inline-size: auto; object-fit: contain; }
  .site-header__logo-img--light { display: none; }
  [data-theme="light"] .site-header__logo-img--dark  { display: none; }
  [data-theme="light"] .site-header__logo-img--light { display: block; }

  /* Nav desktop */
  .site-header__nav { flex: 1; }

  .site-header__nav-list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .site-header__nav-link,
  .site-header__dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding-block: 0.5rem;
    padding-inline: 0.85rem;
    border-radius: var(--radius-m);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-heading);
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition-fast), background var(--transition-fast);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-family-sans);
    white-space: nowrap;

    &:hover {
      color: var(--color-heading);
      background: rgba(255,255,255,0.06);
    }
  }

  .site-header__nav-link--active {
    color: var(--color-primary);
  }

  /* Dropdown servicios */
  .site-header__nav-item--dropdown {
    position: relative;

    &:hover .site-header__dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    &:hover .site-header__dropdown-trigger svg {
      transform: rotate(180deg);
    }
  }

  .site-header__dropdown-trigger svg {
    transition: transform var(--transition-fast);
  }

  .site-header__dropdown {
    position: absolute;
    inset-block-start: calc(100% + 0.5rem);
    inset-inline-start: 0;
    min-inline-size: 16rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-l);
    padding: 0.5rem;
    list-style: none;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity var(--transition-fast), transform var(--transition-fast), visibility var(--transition-fast);
    box-shadow: var(--shadow-l);
  }

  .site-header__dropdown-link {
    display: block;
    padding-block: 0.6rem;
    padding-inline: 1rem;
    border-radius: var(--radius-m);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-body);
    color: var(--color-text);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);

    &:hover {
      background: rgba(56,178,240,0.08);
      color: var(--color-primary);
    }
  }

  /* Acciones */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-inline-start: auto;
  }

  /* Theme toggle */
  .site-header__theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    inline-size: 2.25rem;
    block-size: 2.25rem;
    border-radius: var(--radius-m);
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);

    &:hover { background: rgba(255,255,255,0.1); color: var(--color-heading); }
  }

  .site-header__theme-icon--moon { display: none; }
  [data-theme="light"] .site-header__theme-icon--sun  { display: none; }
  [data-theme="light"] .site-header__theme-icon--moon { display: block; }

  /* Hamburger */
  .site-header__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;

    & span {
      display: block;
      inline-size: 22px;
      block-size: 2px;
      background: var(--color-text);
      border-radius: 2px;
      transition: all var(--transition-fast);
    }

    &[aria-expanded="true"] span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
    &[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    &[aria-expanded="true"] span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
  }

  /* Mobile menu */
  .site-header__mobile-menu {
    display: none;
    overflow: hidden;
    border-block-start: 1px solid var(--color-border);
    padding-inline: var(--spacing-gutter);
    padding-block: 1.5rem;

    & ul { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; }
  }

  .site-header__mobile-link {
    display: block;
    padding-block: 0.65rem;
    padding-inline: 0.75rem;
    border-radius: var(--radius-m);
    font-weight: var(--font-weight-heading);
    color: var(--color-text);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);

    &:hover { background: rgba(255,255,255,0.06); color: var(--color-primary); }
  }

  .site-header__mobile-group-label {
    display: block;
    padding-inline: 0.75rem;
    padding-block-start: 1rem;
    padding-block-end: 0.35rem;
    font-size: var(--font-size-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    font-weight: var(--font-weight-heading);
  }

  .site-header__mobile-submenu { padding-inline-start: 0.75rem; gap: 0 !important; }
  .site-header__mobile-sublink {
    display: block;
    padding-block: 0.5rem;
    padding-inline: 0.75rem;
    border-radius: var(--radius-m);
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);

    &:hover { color: var(--color-primary); }
  }

  /* ── Responsive ── */
  @media (width < 56rem) {
    .site-header__nav { display: none; }
    .site-header__cta { display: none; }
    .site-header__hamburger { display: flex; }
    .site-header__mobile-menu.is-open { display: block; }
  }
</style>

<script>
  // ── Theme toggle ──
  const html = document.documentElement;
  const toggle = document.getElementById('theme-toggle');
  const saved = localStorage.getItem('lf-theme');
  if (saved === 'light') html.setAttribute('data-theme', 'light');

  toggle?.addEventListener('click', () => {
    const isLight = html.getAttribute('data-theme') === 'light';
    html.setAttribute('data-theme', isLight ? 'dark' : 'light');
    localStorage.setItem('lf-theme', isLight ? 'dark' : 'light');
  });

  // ── Mobile menu ──
  const navToggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  navToggle?.addEventListener('click', () => {
    const expanded = navToggle.getAttribute('aria-expanded') === 'true';
    navToggle.setAttribute('aria-expanded', String(!expanded));
    mobileMenu?.setAttribute('aria-hidden', String(expanded));
    mobileMenu?.classList.toggle('is-open');
  });
</script>
