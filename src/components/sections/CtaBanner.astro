---
/** CtaBanner.astro — Sección de cierre con CTA fuerte */

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaUrl?: string;
  ctaSecondaryText?: string;
  ctaSecondaryUrl?: string;
}

const {
  title = '¡Comienza hoy el cambio que estás deseando!',
  subtitle = 'Agéndanos una videollamada y en los próximos 30 días comenzarás a recibir más contactos de calidad.',
  ctaText = 'Agenda tu videollamada gratuita',
  ctaUrl = '/contacto',
  ctaSecondaryText = 'Ver servicios',
  ctaSecondaryUrl = '/servicios',
} = Astro.props;
---

<section class="cta-banner section">
  <div class="cta-banner__container container">
    <div class="cta-banner__inner">
      <header class="cta-banner__header">
        <!-- SEO: keyword en h2 -->
        <h2 class="cta-banner__eyebrow eyebrow">Contáctanos</h2>
        <!-- VISUAL: titular impacto en párrafo -->
        <p class="cta-banner__title h2">{title}</p>
        <p class="cta-banner__subtitle">{subtitle}</p>
      </header>

      <div class="cta-banner__actions">
        <a class="btn btn--primary" href={ctaUrl}>{ctaText}</a>
        <a class="btn btn--ghost" href={ctaSecondaryUrl}>{ctaSecondaryText}</a>
      </div>

      <!-- Stats rápidos -->
      <div class="cta-banner__stats">
        <div class="cta-banner__stat">
          <span class="cta-banner__stat-number">+400</span>
          <span class="cta-banner__stat-label">Clientes atendidos</span>
        </div>
        <div class="cta-banner__stat">
          <span class="cta-banner__stat-number">90</span>
          <span class="cta-banner__stat-label">Días para ver resultados</span>
        </div>
        <div class="cta-banner__stat">
          <span class="cta-banner__stat-number">+25</span>
          <span class="cta-banner__stat-label">Años de experiencia</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: linear-gradient(135deg, rgba(56,178,240,0.08) 0%, rgba(103,197,135,0.06) 100%);
    border-block: 1px solid rgba(56,178,240,0.15);
  }

  .cta-banner__container {
    display: flex;
    justify-content: center;
  }

  .cta-banner__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.5rem;
    max-inline-size: 52rem;
  }

  .cta-banner__header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .cta-banner__subtitle {
    color: var(--color-text-muted);
    max-inline-size: 44ch;
    line-height: 1.7;
  }

  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .cta-banner__stats {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    justify-content: center;
    padding-block-start: 1.5rem;
    border-block-start: 1px solid var(--color-border);
    inline-size: 100%;
  }

  .cta-banner__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .cta-banner__stat-number {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: var(--font-weight-heading);
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .cta-banner__stat-label {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
  }
</style>
