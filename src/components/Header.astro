---
// Header.astro
// Componente de navegación principal.
---
<header class="c-header" id="site-header">
  <div class="o-container c-header__container">
    
    <!-- Lado Izquierdo: Logotipo -->
    <a href="/" class="c-header__brand" aria-label="Volver a la página de inicio">
      <span class="sr-only">LifeFocus</span>
      <!-- Insertar SVG del Logo aquí -->
      <svg class="c-header__logo" width="120" height="40" viewBox="0 0 120 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="120" height="40" rx="4" fill="var(--action-color)" />
        <text x="10" y="25" fill="#fff" font-family="var(--ff-heading)" font-weight="700" font-size="20">Builder</text>
      </svg>
    </a>

    <!-- Navegación Desktop -->
    <nav class="c-header__nav" aria-label="Navegación principal">
      <ul class="c-header__nav-list">
        <li><a href="#servicios" class="c-header__nav-item">Servicios</a></li>
        <li><a href="#metodologia" class="c-header__nav-item">Metodología</a></li>
        <li><a href="#casos" class="c-header__nav-item">Casos de Éxito</a></li>
      </ul>
    </nav>

    <!-- Lado Derecho: Call to Action & Theme Toggle -->
    <div class="c-header__actions">
      <!-- Theme Toggle -->
      <button id="theme-toggle" class="c-theme-toggle" aria-label="Cambiar tema de color">
        <!-- Sun icon (shows in dark mode) -->
        <svg class="sun-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shows in light mode) -->
        <svg class="moon-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <a href="#contacto" class="c-button" data-variant="primary">Agenda una Llamada</a>
    </div>

    <!-- Botón Menú Móvil (Hamburger) -->
    <button class="c-header__mobile-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Abrir menú de navegación">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<script>
  // Lógica de interactividad del Theme Toggle
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");
    
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    element.setAttribute("data-theme", isDark ? "dark" : "light");
    element.style.colorScheme = isDark ? "dark" : "light";
  }

  const themeToggleButton = document.getElementById("theme-toggle");
  if(themeToggleButton){
    themeToggleButton.addEventListener("click", handleToggleClick);
  }
</script>

<style>
/* Los estilos específicos pueden ir aquí de ser necesario para el componente aislado, 
   o preferiblemente en tokens/patterns si son muy reutilizables. */
.c-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: var(--surface-1);
  border-bottom: 1px solid var(--border-color);
  padding-block: var(--space-s);
}

.c-header__container {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.c-header__nav-list {
  display: none; /* Oculto en móvil por defecto */
  gap: var(--space-m);
  list-style: none;
  padding: 0;
  margin: 0;
}

.c-header__nav-item {
  color: var(--text-color);
  text-decoration: none;
  font-weight: 500;
  transition: color var(--transition-fast);
}

.c-header__nav-item:hover {
  color: var(--action-color);
}

.c-header__mobile-toggle {
  display: block;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-color);
}

.c-header__actions {
  display: none;
}

/* Ejemplo simple de Media Query Block-Based (Nivel 3 del Workflow) */
@media (width > 60rem) {
  .c-header__nav-list,
  .c-header__actions {
    display: flex;
  }
  .c-header__mobile-toggle {
    display: none;
  }
}

/* Estilos adicionales para Theme Toggle */
.c-theme-toggle {
  background: transparent;
  border: 1px solid var(--border-color);
  color: var(--text-color);
  border-radius: var(--radius-full);
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.c-theme-toggle:hover {
  background-color: var(--surface-2);
  color: var(--action-color);
}

.sun-icon { display: none; }
.moon-icon { display: block; }

:global([data-theme="dark"]) .sun-icon { display: block; }
:global([data-theme="dark"]) .moon-icon { display: none; }
</style>
