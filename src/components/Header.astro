    <!-- Navegación Desktop -->
    <nav class="c-header__nav" aria-label="Navegación principal">
      <ul class="c-header__nav-list">
        <li><a href="/" class="c-header__nav-item">Inicio</a></li>
        <li><a href="/precios" class="c-header__nav-item">Precios</a></li>
        <li>
          <a href="/soluciones/chatbot-ia" class="c-header__nav-item"
            >Soluciones</a>
        </li>
        <li>
          <a href="/servicios/google-ads" class="c-header__nav-item"
            >Servicios</a>
        </li>
      </ul>
    </nav>

    <!-- Lado Derecho: Call to Action & Theme Toggle -->
    <div class="c-header__actions">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="c-theme-toggle"
        aria-label="Cambiar tema de color"
      >
        <!-- Sun icon (shows in dark mode) -->
        <svg
          class="sun-icon"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          width="20"
          height="20"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
        <!-- Moon icon (shows in light mode) -->
        <svg
          class="moon-icon"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          width="20"
          height="20"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
      </button>

      <a href="#contacto" class="c-button" data-variant="primary"
        >Agenda una Llamada</a
      >
    </div>

    <!-- Botón Menú Móvil (Hamburger) -->
    <button
      class="c-header__mobile-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú de navegación"
    >
      <svg
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<script>
  // Lógica de interactividad del Theme Toggle
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    element.setAttribute("data-theme", isDark ? "dark" : "light");
    element.style.colorScheme = isDark ? "dark" : "light";
  };

  const themeToggleButton = document.getElementById("theme-toggle");
  if (themeToggleButton) {
    themeToggleButton.addEventListener("click", handleToggleClick);
  }
</script>

