---
// PriceCard.astro
interface Props {
    title: string;
    price: string;
    description: string;
    features: string[];
    isPopular?: boolean;
    ctaText?: string;
}

const {
    title,
    price,
    description,
    features,
    isPopular = false,
    ctaText = "Seleccionar Plan",
} = Astro.props;
---

<article class={`c-price-card ${isPopular ? "c-price-card--popular" : ""}`}>
    {isPopular && <span class="c-price-card__badge">Más Popular</span>}
    <header class="c-price-card__header">
        <h3 class="h4">{title}</h3>
        <div class="c-price-card__price">
            <span class="c-price-card__currency">$</span>
            <span class="c-price-card__amount">{price}</span>
            <span class="c-price-card__period">/mes</span>
        </div>
        <p class="c-price-card__desc">{description}</p>
    </header>

    <ul class="c-price-card__features">
        {features.map((feature) => <li>{feature}</li>)}
    </ul>

    <footer class="c-price-card__footer">
        <a
            href="/contacto"
            class={`c-button ${isPopular ? "" : 'data-variant="outline"'}`}
            data-variant={isPopular ? "primary" : "outline"}
        >
            {ctaText}
        </a>
    </footer>
</article>

<style>
    .c-price-card {
        background-color: var(--color-surface);
        padding: var(--space-xl);
        border-radius: var(--radius-l);
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        position: relative;
        transition: all var(--transition-normal);
    }

    .c-price-card--popular {
        border-color: var(--primary);
        transform: scale(1.05);
        box-shadow: var(--shadow-l);
        z-index: 2;
    }

    .c-price-card__badge {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translate(-50%, -50%);
        background-color: var(--primary);
        color: white;
        padding: var(--space-xxs) var(--space-s);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        font-weight: var(--weight-bold);
        text-transform: uppercase;
    }

    .c-price-card__header {
        margin-block-end: var(--space-l);
        text-align: center;
    }

    .c-price-card__price {
        margin-block: var(--space-s);
        color: var(--color-text-heading);
        font-family: var(--font-heading);
    }

    .c-price-card__amount {
        font-size: var(--text-xxl);
        font-weight: var(--weight-black);
    }

    .c-price-card__currency,
    .c-price-card__period {
        font-size: var(--text-m);
        font-weight: var(--weight-medium);
        opacity: 0.7;
    }

    .c-price-card__desc {
        font-size: var(--text-s);
        opacity: 0.8;
    }

    .c-price-card__features {
        list-style: none;
        padding: 0;
        margin: 0;
        margin-block-end: var(--space-xl);
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
        font-size: var(--text-s);
    }

    .c-price-card__features li {
        display: flex;
        gap: var(--space-xs);
        align-items: center;
    }

    .c-price-card__features li::before {
        content: "✓";
        color: var(--secondary);
        font-weight: var(--weight-bold);
    }

    .c-price-card__footer {
        margin-block-start: auto;
    }

    .c-price-card__footer .c-button {
        width: 100%;
        justify-content: center;
    }
</style>
