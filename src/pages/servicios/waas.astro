---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Faq from '../../components/sections/Faq.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import type { PageMeta } from '../../types/cms';

const meta: PageMeta = {
  title: 'WaaS — Web as a Service | Life Focus Agency',
  description: 'Sistema completo: sitio web de alto rendimiento + CRM + chatbot. Genera leads 24/7. Setup $390 + desde $270/mes. Para negocios latinos en USA.',
  lang: 'es',
};

const includes = [
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/>`, title: 'Sitio web de alto rendimiento', body: 'HTML semántico, SEO técnico, Core Web Vitals optimizados, diseño a medida. No hay atajos.' },
  { icon: `<path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2z"/><path d="M7 7h.01"/>`, title: 'CMS para gestión de contenidos', body: 'Actualiza textos, imágenes y contenido básico sin necesidad de un desarrollador.' },
  { icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`, title: 'CRM integrado', body: 'Registro automático de leads, seguimiento de estado e historial completo de contactos.' },
  { icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`, title: 'Chatbot entrenado 24/7', body: 'Captura leads automáticamente, responde preguntas frecuentes y envía datos al CRM.' },
  { icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`, title: 'Hosting y mantenimiento', body: 'Infraestructura en Cloudflare Pages, actualizaciones y soporte técnico incluidos.' },
  { icon: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`, title: 'Reportes claros', body: 'Informes comprensibles cada mes. Sabes exactamente qué pasa con tu sitio y tus leads.' },
];
---

<BaseLayout meta={meta} currentPage="/servicios">
  <main id="main-content">
    <PageHero
      eyebrow="WaaS — Web as a Service"
      headline="No es un sitio web. Es un sistema de leads que trabaja las 24 horas."
      description="Setup único de $390 + mensualidad desde $270/mes. Contrato mínimo 6 meses. Sistemas completos para el mercado latinoamericano en USA."
      breadcrumb="Servicios / WaaS"
    />

    <!-- Qué incluye -->
    <section class="waas-includes section">
      <div class="waas-includes__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Qué incluye el WaaS</h2>
          <p class="h2">Todo lo que necesitas, sin complicaciones</p>
          <p class="section-header__desc">Un solo servicio que integra todo lo que tu negocio necesita para generar leads de calidad de forma consistente.</p>
        </header>

        <div class="waas-includes__grid">
          {includes.map(item => (
            <div class="waas-includes__item card">
              <div class="waas-includes__icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
              </div>
              <div>
                <h3 class="eyebrow" style="margin-block-end: 0.4rem">{item.title}</h3>
                <p class="waas-body">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cómo se diferencia -->
    <section class="waas-diff section section--alt">
      <div class="waas-diff__container container">
        <div class="waas-diff__grid">
          <header class="section-header">
            <h2 class="eyebrow">Cómo se diferencia</h2>
            <p class="h2">No es como los demás sitios web.</p>
            <p class="section-header__desc">La mayoría de agencias te entregan un sitio y desaparecen. Con el WaaS, somos parte de tu equipo de crecimiento.</p>
          </header>

          <div class="waas-diff__compare">
            <div class="waas-diff__col">
              <h3 class="eyebrow" style="color: var(--color-text-muted)">Un sitio web normal</h3>
              <ul class="waas-diff__list waas-diff__list--bad">
                <li>Te entregan el sitio y te olvidan</li>
                <li>No incluye CRM ni seguimiento de leads</li>
                <li>Sin soporte ni actualizaciones</li>
                <li>Sin estrategia de conversión</li>
                <li>Pagas de nuevo por cada cambio</li>
              </ul>
            </div>
            <div class="waas-diff__col">
              <h3 class="eyebrow">WaaS — Life Focus</h3>
              <ul class="waas-diff__list waas-diff__list--good">
                <li>Soporte y acompañamiento continuo</li>
                <li>CRM + chatbot integrados desde el inicio</li>
                <li>Mantenimiento y cambios incluidos</li>
                <li>Diseñado para convertir visitas en leads</li>
                <li>Reportes mensuales transparentes</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Precio único -->
    <section class="waas-price section">
      <div class="waas-price__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Inversión</h2>
          <p class="h2">Un sistema completo, un precio predecible.</p>
        </header>

        <div class="waas-price__card card">
          <div class="waas-price__inner">
            <div class="waas-price__info">
              <p class="eyebrow" style="margin-block-end: 0.75rem">WaaS — Web as a Service</p>
              <div class="waas-price__rows">
                <div class="waas-price__row">
                  <span>Setup inicial (única vez)</span>
                  <span class="waas-price__amount">$390</span>
                </div>
                <div class="waas-price__row">
                  <span>Mensualidad (mín. 6 meses)</span>
                  <span class="waas-price__amount">$270<small>/mes</small></span>
                </div>
              </div>
              <p class="waas-price__note">
                El sistema completo incluye web, CRM y chatbot. Hosting, soporte y actualizaciones incluidos en la mensualidad.
              </p>
            </div>

            <ul class="waas-price__list">
              {[
                'Sitio web de alto rendimiento',
                'CMS para gestión de contenidos',
                'CRM integrado para seguimiento de leads',
                'Chatbot entrenado 24/7',
                'Hosting en Cloudflare (ultra rápido)',
                'Soporte y actualizaciones incluidas',
                'Reporte mensual de leads',
                'Sin costos ocultos ni sorpresas',
              ].map(f => <li>✓ {f}</li>)}
            </ul>

            <a class="btn btn--primary waas-price__cta" href="/contacto">
              Empieza con el WaaS →
            </a>
          </div>
        </div>
      </div>
    </section>

    <Testimonials />
    <Faq />
    <CtaBanner
      title="¿Listo para comenzar?"
      subtitle="En 30 días tendrás tu sistema de leads funcionando. Agenda una llamada gratuita."
      ctaText="Empieza con el WaaS"
    />
  </main>
</BaseLayout>

<style>
  .waas-includes__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .waas-includes__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    @container (inline-size < 52rem) { grid-template-columns: repeat(2, 1fr); }
    @container (inline-size < 32rem) { grid-template-columns: 1fr; }
  }
  .waas-includes__item { display: flex; gap: 1rem; align-items: flex-start; }
  .waas-includes__icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 3rem; block-size: 3rem; flex-shrink: 0;
    border-radius: var(--radius-m); background: rgba(56,178,240,0.08);
    border: 1px solid rgba(56,178,240,0.2); color: var(--color-primary);
  }
  [data-theme="light"] .waas-includes__icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .waas-body { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .waas-diff__container { :has(> &) { container-type: inline-size; } }
  .waas-diff__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .waas-diff__compare {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
    @container (inline-size < 30rem) { grid-template-columns: 1fr; }
  }
  .waas-diff__col { display: flex; flex-direction: column; gap: 1rem; }
  .waas-diff__list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .waas-diff__list li {
    font-size: var(--font-size-small); color: var(--color-text-muted);
    padding-inline-start: 1.25rem; position: relative;
    &::before { content: '×'; position: absolute; inset-inline-start: 0; color: #ef4444; }
  }
  .waas-diff__list--good li {
    color: var(--color-text);
    &::before { content: '✓'; color: var(--color-secondary); }
  }

  .waas-price__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .waas-price__card { max-inline-size: 54rem; margin-inline: auto; padding: 2.5rem; container-type: inline-size; }
  .waas-price__inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;
    @container (inline-size < 36rem) { grid-template-columns: 1fr; }
  }
  .waas-price__info { display: flex; flex-direction: column; }
  .waas-price__rows { margin-block: 0.75rem; border-block: 1px solid var(--color-border); }
  .waas-price__row {
    display: flex; justify-content: space-between; align-items: center;
    padding-block: 0.9rem; border-block-end: 1px solid var(--color-border); font-size: var(--font-size-small); color: var(--color-text-muted);
    &:last-child { border-block-end: none; }
  }
  .waas-price__amount {
    font-size: 1.5rem; font-weight: var(--font-weight-heading);
    background: var(--gradient-brand); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    & small { font-size: 0.85rem; font-weight: 300; }
  }
  .waas-price__note { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.55; margin-block-start: 0.75rem; }
  .waas-price__list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; font-size: var(--font-size-small); }
  .waas-price__cta { margin-block-start: 1.5rem; grid-column: span 2; justify-content: center; @container (inline-size < 36rem) { grid-column: span 1; } }
</style>
