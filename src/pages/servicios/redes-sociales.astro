---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Faq from '../../components/sections/Faq.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import type { PageMeta } from '../../types/cms';

const meta: PageMeta = {
  title: 'Gestión de Redes Sociales para Negocios Latinos en USA | Life Focus Agency',
  description: 'Creación de contenido orgánico y gestión de redes sociales para negocios latinos en USA. Desde $490/mes. Estrategia, gráficas y copywriting incluidos.',
  lang: 'es',
};

const includes = [
  { icon: `<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>`, title: 'Estrategia de contenido', body: 'Calendario editorial mensual alineado a tus objetivos de negocio y al ciclo de compra de tu cliente.' },
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`, title: 'Diseño de gráficas', body: 'Piezas visuales para feed, stories y reels. Consistentes con tu identidad de marca y optimizadas para cada formato.' },
  { icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`, title: 'Copywriting incluido', body: 'Textos persuasivos y naturales para cada publicación, adaptados al tono de tu negocio y al idioma de tu audiencia.' },
  { icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`, title: 'Gestión y publicación', body: 'Publicación programada, respuesta a comentarios básicos y monitoreo activo de tu comunidad online.' },
  { icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`, title: 'Análisis mensual', body: 'Revisión de métricas de rendimiento y ajuste de estrategia cada mes. No trabajamos en piloto automático.' },
  { icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`, title: 'Reporte mensual', body: 'Métricas de alcance, interacción y crecimiento. Informe en español, claro y fácil de entender.' },
];
---

<BaseLayout meta={meta} currentPage="/servicios">
  <main id="main-content">
    <PageHero
      eyebrow="Redes Sociales Orgánicas para Negocios Latinos en USA"
      headline="Construye autoridad y confianza, mes a mes."
      description="Desde $490/mes. Estrategia de contenido, creación de gráficas, copywriting y gestión completa de tus redes sociales para el mercado latino en USA."
      breadcrumb="Servicios / Redes Sociales"
    />

    <!-- Qué incluye -->
    <section class="social-includes section">
      <div class="social-includes__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Qué incluye la gestión de redes</h2>
          <p class="h2">Contenido con propósito, no solo publicaciones.</p>
          <p class="section-header__desc">No publicamos por publicar. Cada pieza de contenido tiene un objetivo claro dentro de tu estrategia de crecimiento digital.</p>
        </header>

        <div class="social-grid">
          {includes.map(item => (
            <div class="social-item card">
              <div class="svc-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
              </div>
              <div>
                <h3 class="eyebrow" style="margin-block-end: 0.35rem">{item.title}</h3>
                <p class="svc-body">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cómo se diferencia -->
    <section class="social-diff section section--alt">
      <div class="social-diff__container container">
        <div class="social-diff__grid">
          <header class="section-header">
            <h2 class="eyebrow">Cómo se diferencia</h2>
            <p class="h2">Contenido orgánico real.</p>
            <p class="section-header__desc">No usamos plantillas de Canva genéricas. Creamos contenido que realmente detiene el scroll y genera conversación con tu audiencia.</p>
          </header>

          <div class="social-diff__compare">
            <div class="dw-diff__col">
              <h3 class="eyebrow" style="color: var(--color-text-muted)">Gestión típica</h3>
              <ul class="dw-diff__list dw-diff__list--bad">
                <li>3 posts al azar por semana</li>
                <li>Diseños genéricos y stock</li>
                <li>Copy que nadie lee</li>
                <li>Ignoran los comentarios</li>
                <li>Sin estrategia de marca</li>
              </ul>
            </div>
            <div class="dw-diff__col">
              <h3 class="eyebrow">Life Focus — Engagement</h3>
              <ul class="dw-diff__list dw-diff__list--good">
                <li>Estrategia editorial mensual</li>
                <li>Diseño gráfico profesional</li>
                <li>Copywriting persuasivo</li>
                <li>Gestión activa de comunidad</li>
                <li>Consistencia de marca total</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Por qué funciona -->
    <section class="social-why section">
      <div class="social-why__container container">
        <div class="social-why__grid">
          <header class="section-header">
            <h2 class="eyebrow">Por qué funciona</h2>
            <p class="h2">Las redes sociales no son sobre likes. Son sobre confianza.</p>
            <p class="section-header__desc">En el mercado latino, la confianza lo es todo. A nadie le contratas si no lo conoces. Las redes son el camino más natural para construir esa relación.</p>
          </header>
          <ul class="social-why__list">
            {[
              [
                `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
                'Contenido alineado a ventas',
                'Cada publicación tiene un rol dentro del ciclo de compra: awareness, consideración o conversión.'
              ],
              [
                `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
                'Enfoque en el mercado latino en USA',
                'Mensajes que hablan el idioma cultural de tu audiencia, no traducciones genéricas.'
              ],
              [
                `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
                'Combinado con pauta, multiplica',
                'Las redes orgánicas funcionan mejor con Meta Ads. Te ayudamos a integrar ambas cuando sea el momento.'
              ],
            ].map(([iconPath, title, body]) => (
              <li class="social-why__item">
                <div class="social-why__icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={iconPath}></svg>
                </div>
                <div>
                  <strong>{title}</strong>
                  <p>{body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Precio -->
    <section class="social-price section section--alt">
      <div class="social-price__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Inversión</h2>
          <p class="h2">Precio mensual, todo incluido.</p>
        </header>

        <div class="social-price__card card">
          <div class="social-price__content">
            <div class="social-price__main">
              <span class="eyebrow" style="color: var(--color-primary)">Redes Sociales — Presencia</span>
              <div class="social-price__amount-row">
                <span class="social-price__label">desde</span>
                <span class="social-price__price">$490</span>
                <span class="social-price__sub">USD/mes</span>
              </div>
              <p class="social-price__tagline">Construye una comunidad fiel con contenido que realmente detiene el scroll.</p>
              
              <div class="social-price__recommendation">
                <p>💡 <strong>Recomendación</strong></p>
                <p>Combina con Meta Ads para amplificar tu alcance orgánico.</p>
                <a href="/servicios/meta-ads">Ver Meta Ads →</a>
              </div>

              <div class="social-price__cta-desktop">
                <a class="btn btn--primary" href="/contacto">Solicitar plan de contenido →</a>
              </div>
            </div>

            <div class="social-price__separator" aria-hidden="true"></div>

            <div class="social-price__features">
              <p class="social-price__features-title">Incluido mensualmente:</p>
              <ul class="social-price__list">
                {[
                  'Estrategia editorial mensual',
                  'Diseño de gráficas profesional',
                  'Copywriting para cada post',
                  'Gestión y publicación (Feed/Stories)',
                  'Interacción activa con seguidores',
                  'Reporte mensual de métricas',
                ].map(item => (
                  <li>
                    <svg class="social-price__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="social-price__cta-mobile">
            <a class="btn btn--primary btn--full" href="/contacto">Solicitar plan de contenido →</a>
          </div>
        </div>
      </div>
    </section>

    <Testimonials />
    <Faq />
    <CtaBanner
      title="¿Quieres una presencia digital que inspire confianza?"
      subtitle="Agenda una llamada y diseñamos juntos la estrategia de contenido para tu negocio."
      ctaText="Hablar con un experto"
    />
  </main>
</BaseLayout>

<style>
  .social-includes__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .social-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
    @container (inline-size < 52rem) { grid-template-columns: repeat(2, 1fr); }
    @container (inline-size < 32rem) { grid-template-columns: 1fr; }
  }
  .social-item { display: flex; gap: 1rem; align-items: flex-start; }
  .svc-icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 3rem; block-size: 3rem; flex-shrink: 0;
    border-radius: var(--radius-m); background: rgba(56,178,240,0.08);
    border: 1px solid rgba(56,178,240,0.2); color: var(--color-primary);
  }
  [data-theme="light"] .svc-icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .svc-body { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .social-diff__container { :has(> &) { container-type: inline-size; } }
  .social-diff__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .social-diff__compare {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    @container (inline-size < 30rem) { grid-template-columns: 1fr; }
  }
  /* Estilos reusados de diseno-web por consistencia */
  .dw-diff__col { display: flex; flex-direction: column; gap: 1rem; }
  .dw-diff__list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .dw-diff__list li {
    font-size: var(--font-size-small); color: var(--color-text-muted);
    padding-inline-start: 1.5rem; position: relative;
    &::before { content: '×'; position: absolute; inset-inline-start: 0; color: #ef4444; font-weight: bold; }
  }
  .dw-diff__list--good li {
    color: var(--color-text);
    &::before { content: '✓'; color: var(--color-secondary); }
  }

  .social-why__container { :has(> &) { container-type: inline-size; } }
  .social-why__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .social-why__list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
  .social-why__item { display: flex; gap: 1rem; align-items: flex-start; }
  .social-why__icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 2.5rem; block-size: 2.5rem; flex-shrink: 0;
    border-radius: var(--radius-m);
    background: rgba(56,178,240,0.08); border: 1px solid rgba(56,178,240,0.2);
    color: var(--color-primary);
  }
  [data-theme="light"] .social-why__icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .social-why__item strong { display: block; font-weight: var(--font-weight-heading); color: var(--color-heading); font-size: var(--font-size-body); margin-block-end: 0.25rem; }
  .social-why__item p { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .social-price__card {
    max-inline-size: 64rem; margin-inline: auto; padding: 4rem; overflow: hidden;
    background: linear-gradient(145deg, var(--color-surface), rgba(56,178,240,0.03));
  }
  .social-price__content { display: flex; gap: 4rem; align-items: stretch; }
  .social-price__main { flex: 1.2; display: flex; flex-direction: column; justify-content: center; }
  .social-price__separator { inline-size: 1px; background: var(--color-border); filter: opacity(0.5); }
  .social-price__features { flex: 1; display: flex; flex-direction: column; justify-content: center; }

  .social-price__amount-row { display: flex; align-items: baseline; gap: 0.75rem; margin-block: 1.5rem; }
  .social-price__label { font-size: var(--font-size-small); color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .social-price__price { font-size: clamp(3rem, 6vw, 4.5rem); font-weight: 600; color: var(--color-heading); line-height: 1; }
  .social-price__sub { font-size: 1.25rem; color: var(--color-text-muted); font-weight: 300; }
  .social-price__tagline { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.5; margin-block-end: 2rem; max-inline-size: 24rem; }

  .social-price__recommendation {
    margin-block-end: 2rem; padding: 1.25rem; background: rgba(56,178,240,0.05); border: 1px solid rgba(56,178,240,0.1); border-radius: var(--radius-m);
    font-size: 0.8rem; color: var(--color-text-muted);
    & a { color: var(--color-primary); display: inline-block; margin-block-start: 0.25rem; }
    & strong { color: var(--color-heading); }
  }

  .social-price__features-title { font-weight: 500; color: var(--color-heading); margin-block-end: 1.5rem; font-size: var(--font-size-body); }
  .social-price__list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .social-price__list li { display: flex; align-items: center; gap: 0.75rem; font-size: var(--font-size-small); color: var(--color-text); }
  .social-price__check { color: var(--color-secondary); flex-shrink: 0; }

  .social-price__cta-mobile { display: none; margin-block-start: 2.5rem; }

  @media (max-width: 54rem) {
    .social-price__card { padding: 2.5rem; }
    .social-price__content { flex-direction: column; gap: 2.5rem; }
    .social-price__main { align-items: center; text-align: center; }
    .social-price__tagline { margin-inline: auto; }
    .social-price__separator { inline-size: 100%; block-size: 1px; }
    .social-price__cta-desktop { display: none; }
    .social-price__cta-mobile { display: block; }
    .social-price__amount-row { justify-content: center; }
  }
</style>
