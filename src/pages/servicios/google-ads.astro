---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Faq from '../../components/sections/Faq.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import type { PageMeta } from '../../types/cms';

const meta: PageMeta = {
  title: 'Google Ads para Negocios Latinos en USA | Life Focus Agency',
  description: 'Gestión profesional de Google Ads con estrategia long tail. Setup $390 + gestión $290/mes. Campañas que convierten para negocios latinos en USA.',
  lang: 'es',
};

const includes = [
  { icon: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`, title: 'Auditoría inicial gratuita', body: 'Analizamos tu negocio, competencia y palabras clave de alta intención. Identificamos oportunidades reales.' },
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/>`, title: 'Estructura de campaña', body: 'Grupos de anuncios bien segmentados sin mezclar intenciones. Copy persuasivo y extensiones bien configuradas.' },
  { icon: `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`, title: 'Lista de negativos exhaustiva', body: 'Trabajamos los negativos desde el día uno para evitar clics irrelevantes y no desperdiciar tu presupuesto.' },
  { icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`, title: 'Optimización continua', body: 'Revisión semanal de datos, ajustes de puja, negativos nuevos y mejoras de copy basadas en rendimiento real.' },
  { icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`, title: 'Consultoría incluida', body: 'Acceso directo al equipo para consultas. No somos una caja negra: explicamos cada decisión.' },
  { icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`, title: 'Reporte mensual claro', body: 'Informe en español con métricas que entiende un dueño de negocio: leads, costo por lead, y next steps.' },
];
---

<BaseLayout meta={meta} currentPage="/servicios">
  <main id="main-content">
    <PageHero
      eyebrow="Google Ads — Búsquedas de Alta Intención para Negocios Latinos en USA"
      headline="Deja de alimentar a Google. Empieza a convertir búsquedas en clientes."
      description="Setup $390 + gestión desde $290/mes. Estrategia long tail con negativos trabajados para maximizar conversión desde el primer mes."
      breadcrumb="Servicios / Google Ads"
    />

    <!-- Qué incluye -->
    <section class="gads-includes section">
      <div class="gads-includes__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Qué incluye la gestión de Google Ads</h2>
          <p class="h2">Long tail: menos gasto, más conversión.</p>
          <p class="section-header__desc">El secreto está en las palabras clave de alta intención y los negativos bien trabajados. Tu presupuesto va exactamente donde debe ir.</p>
        </header>

        <div class="gads-grid">
          {includes.map(item => (
            <div class="gads-item card">
              <div class="svc-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
              </div>
              <div>
                <h3 class="eyebrow" style="margin-block-end: 0.35rem">{item.title}</h3>
                <p class="svc-body">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cómo se diferencia -->
    <section class="gads-diff section section--alt">
      <div class="gads-diff__container container">
        <div class="gads-diff__grid">
          <header class="section-header">
            <h2 class="eyebrow">Cómo se diferencia</h2>
            <p class="h2">Auditamos para ganar.</p>
            <p class="section-header__desc">La mayoría de las agencias hacen "setup y olvido". Nosotros optimizamos cada semana buscando rentabilidad real.</p>
          </header>

          <div class="gads-diff__compare">
            <div class="gads-diff__col">
              <h3 class="eyebrow" style="color: var(--color-text-muted)">Gestión normal</h3>
              <ul class="gads-diff__list gads-diff__list--bad">
                <li>Setup y olvido absoluto</li>
                <li>Sin lista de palabras negativas</li>
                <li>Reportes que no se entienden</li>
                <li>Solo buscan clics, no ventas</li>
                <li>Costos ocultos por "gestión"</li>
              </ul>
            </div>
            <div class="gads-diff__col">
              <h3 class="eyebrow">Life Focus — Estrategia</h3>
              <ul class="gads-diff__list gads-diff__list--good">
                <li>Optimización semanal real</li>
                <li>Lista de negros desde el día 1</li>
                <li>Reportes claros en español</li>
                <li>Enfoque total en leads de calidad</li>
                <li>Inversión transparente sin trucos</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Nuestra metodología -->
    <section class="gads-method section">
      <div class="gads-method__container container">
        <div class="gads-method__grid">
          <header class="section-header">
            <h2 class="eyebrow">Nuestra Metodología</h2>
            <p class="h2">Un proceso probado en más de 400 negocios.</p>
            <p class="section-header__desc">No improvisamos. Tenemos un proceso sistemático que ha funcionado para restaurantes, clínicas, constructoras y servicios en USA.</p>
          </header>
          <ul class="gads-steps">
            {[
              [
                `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
                'Semana 1',
                'Auditoría + Keywords',
                'Investigación profunda de palabras clave con intención de compra real.'
              ],
              [
                `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>`,
                'Semana 2',
                'Setup de campaña',
                'Estructura, anuncios, extensiones, negativos y tracking de conversiones.'
              ],
              [
                `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
                'Semanas 3–4',
                'Primera optimización',
                'Con datos reales ajustamos pujas, pausamos lo que no convierte.'
              ],
              [
                `<path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>`,
                'Mes 2+',
                'Optimización continua',
                'Ciclo mensual de mejora: ROAS en constante crecimiento.'
              ],
            ].map(([icon, label, title, body]) => (
              <li class="gads-step">
                <div class="gads-step__icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icon}></svg>
                </div>
                <div class="gads-step__content">
                  <span class="gads-step__label eyebrow">{label}</span>
                  <strong>{title}</strong>
                  <p>{body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Precio -->
    <section class="gads-price section section--alt">
      <div class="gads-price__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Inversión</h2>
          <p class="h2">Precio transparente, sin sorpresas.</p>
        </header>

        <div class="gads-price__card card">
          <div class="gads-price__content">
            <div class="gads-price__main">
              <span class="eyebrow" style="color: var(--color-primary)">Google Ads — Gestión Pro</span>
              <div class="gads-price__rows">
                <div class="gads-price__row">
                  <div class="gads-price__label-group">
                    <span class="gads-price__label">Setup inicial</span>
                    <span class="gads-price__sub">Única vez</span>
                  </div>
                  <span class="gads-price__amount">$390<small>USD</small></span>
                </div>
                <div class="gads-price__row">
                  <div class="gads-price__label-group">
                    <span class="gads-price__label">Gestión mensual</span>
                    <span class="gads-price__sub">Sin contratos forzosos</span>
                  </div>
                  <span class="gads-price__amount">$290<small>USD/mes</small></span>
                </div>
              </div>
              <p class="gads-price__tagline">Optimización continua para maximizar tu ROI. Tú pones el presupuesto, nosotros los resultados.</p>
              <div class="gads-price__cta-desktop">
                <a class="btn btn--primary" href="/contacto">Comenzar con Google Ads →</a>
              </div>
            </div>

            <div class="gads-price__separator" aria-hidden="true"></div>

            <div class="gads-price__features">
              <p class="gads-price__features-title">Incluido en la gestión:</p>
              <ul class="gads-price__list">
                {[
                  'Auditoría estratégica inicial',
                  'Setup completo de campañas',
                  'Búsqueda de keywords Ganadoras',
                  'Gestión de Negativos semanal',
                  'Configuración de Conversiones Pro',
                  'Reporte mensual de rendimiento',
                ].map(item => (
                  <li>
                    <svg class="gads-price__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div class="gads-price__cta-mobile">
            <a class="btn btn--primary btn--full" href="/contacto">Comenzar con Google Ads →</a>
          </div>
        </div>
      </div>
    </section>
      </div>
    </section>

    <Testimonials />
    <Faq />
    <CtaBanner
      title="¿Tus Google Ads no convierten?"
      subtitle="Agenda una auditoría gratuita. Revisamos tu cuenta y te decimos qué está pasando."
      ctaText="Solicitar auditoría gratuita"
    />
  </main>
</BaseLayout>

<style>
  .gads-includes__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .gads-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
    @container (inline-size < 52rem) { grid-template-columns: repeat(2, 1fr); }
    @container (inline-size < 32rem) { grid-template-columns: 1fr; }
  }
  .gads-item { display: flex; gap: 1rem; align-items: flex-start; }
  .svc-icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 3rem; block-size: 3rem; flex-shrink: 0;
    border-radius: var(--radius-m); background: rgba(56,178,240,0.08);
    border: 1px solid rgba(56,178,240,0.2); color: var(--color-primary);
  }
  [data-theme="light"] .svc-icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .svc-body { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .gads-diff__container { :has(> &) { container-type: inline-size; } }
  .gads-diff__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .gads-diff__compare {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    @container (inline-size < 30rem) { grid-template-columns: 1fr; }
  }
  .gads-diff__col { display: flex; flex-direction: column; gap: 1rem; }
  .gads-diff__list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .gads-diff__list li {
    font-size: var(--font-size-small); color: var(--color-text-muted);
    padding-inline-start: 1.5rem; position: relative;
    &::before { content: '×'; position: absolute; inset-inline-start: 0; color: #ef4444; font-weight: bold; }
  }
  .gads-diff__list--good li {
    color: var(--color-text);
    &::before { content: '✓'; color: var(--color-secondary); }
  }

  .gads-method__container { :has(> &) { container-type: inline-size; } }
  .gads-method__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .gads-steps { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .gads-step {
    display: flex; gap: 1.5rem; padding-block: 2rem; border-block-end: 1px solid var(--color-border);
    &:last-child { border-block-end: none; }
  }
  .gads-step__icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 3rem; block-size: 3rem; flex-shrink: 0;
    border-radius: var(--radius-m); background: rgba(56,178,240,0.08);
    border: 1px solid rgba(56,178,240,0.2); color: var(--color-primary);
  }
  [data-theme="light"] .gads-step__icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .gads-step__content { display: flex; flex-direction: column; gap: 0.25rem; }
  .gads-step__content strong { font-weight: var(--font-weight-heading); color: var(--color-heading); font-size: var(--font-size-body); }
  .gads-step__content p { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .gads-price__card {
    max-inline-size: 64rem; margin-inline: auto; padding: 4rem; overflow: hidden;
    background: linear-gradient(145deg, var(--color-surface), rgba(56,178,240,0.03));
  }
  .gads-price__content { display: flex; gap: 4rem; align-items: stretch; }
  .gads-price__main { flex: 1.2; display: flex; flex-direction: column; justify-content: center; }
  .gads-price__separator { inline-size: 1px; background: var(--color-border); filter: opacity(0.5); }
  .gads-price__features { flex: 1; display: flex; flex-direction: column; justify-content: center; }

  .gads-price__rows { margin-block: 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .gads-price__row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.25rem; background: rgba(255,255,255,0.02); border: 1px solid var(--color-border); border-radius: var(--radius-m);
  }
  .gads-price__label-group { display: flex; flex-direction: column; gap: 0.15rem; }
  .gads-price__label { font-size: var(--font-size-body); font-weight: 500; color: var(--color-heading); }
  .gads-price__sub { font-size: 0.75rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  
  .gads-price__amount { font-size: 1.75rem; font-weight: 600; color: var(--color-primary); }
  .gads-price__amount small { font-size: 0.85rem; font-weight: 300; margin-inline-start: 0.35rem; color: var(--color-text-muted); }

  .gads-price__tagline { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.5; margin-block-end: 2rem; }

  .gads-price__features-title { font-weight: 500; color: var(--color-heading); margin-block-end: 1.5rem; font-size: var(--font-size-body); }
  .gads-price__list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .gads-price__list li { display: flex; align-items: center; gap: 0.75rem; font-size: var(--font-size-small); color: var(--color-text); }
  .gads-price__check { color: var(--color-secondary); flex-shrink: 0; }

  .gads-price__cta-mobile { display: none; margin-block-start: 2.5rem; }

  @media (max-width: 54rem) {
    .gads-price__card { padding: 2.5rem; }
    .gads-price__content { flex-direction: column; gap: 2.5rem; }
    .gads-price__main { items: center; text-align: center; }
    .gads-price__separator { inline-size: 100%; block-size: 1px; }
    .gads-price__cta-desktop { display: none; }
    .gads-price__cta-mobile { display: block; }
    .gads-price__row { padding: 1rem; }
  }
</style>
