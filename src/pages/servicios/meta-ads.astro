---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Faq from '../../components/sections/Faq.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import type { PageMeta } from '../../types/cms';

const meta: PageMeta = {
  title: 'Meta Ads — Facebook e Instagram para Negocios Latinos en USA | Life Focus Agency',
  description: 'Gestión de campañas en Facebook e Instagram para negocios latinos en USA. Desde $490/mes. Diseño de gráficas incluido. Segmentación precisa del público latino.',
  lang: 'es',
};

const includes = [
  { icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`, title: 'Estrategia de audiencias', body: 'Segmentación precisa por ubicación, idioma, intereses y comportamientos. Nuestro approach para el público latino en USA.' },
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`, title: 'Diseño de gráficas', body: 'Creativos visuales adaptados a cada formato: feed, stories, reels y más. Incluido en el servicio mensual.' },
  { icon: `<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>`, title: 'Copy persuasivo', body: 'Textos de anuncios orientados a generar clics y leads, no solo impresiones. Pruebas A/B de mensajes incluidas.' },
  { icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`, title: 'Optimización continua', body: 'Ajustes semanales basados en datos para mejorar el rendimiento campaña a campaña. Sin piloto automático.' },
  { icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`, title: 'Consultoría incluida', body: 'Acceso directo al equipo para consultas. Te explicamos cada decisión, sin jerga técnica y sin cajas negras.' },
  { icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`, title: 'Reporte mensual', body: 'Informe comprensible con métricas reales de alcance, clics, leads y costo por resultado. En español.' },
];
---

<BaseLayout meta={meta} currentPage="/servicios">
  <main id="main-content">
    <PageHero
      eyebrow="Meta Ads — Facebook e Instagram para Negocios Latinos en USA"
      headline="Llega a tus clientes ideales donde ya pasan su tiempo."
      description="Desde $490/mes con diseño de gráficas incluido. Segmentación precisa del público latino en USA para generar leads de calidad desde el primer mes."
      breadcrumb="Servicios / Meta Ads"
    />

    <!-- Qué incluye -->
    <section class="meta-includes section">
      <div class="meta-includes__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Qué incluye la gestión de Meta Ads</h2>
          <p class="h2">Más que publicidad: una estrategia visual completa.</p>
          <p class="section-header__desc">Mientras otros solo "prenden" las campañas, nosotros construimos una estrategia completa con creativos, audiencias y optimización permanente.</p>
        </header>

        <div class="meta-grid">
          {includes.map(item => (
            <div class="meta-item card">
              <div class="svc-icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
              </div>
              <div>
                <h3 class="eyebrow" style="margin-block-end: 0.35rem">{item.title}</h3>
                <p class="svc-body">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cómo se diferencia -->
    <section class="meta-diff section section--alt">
      <div class="meta-diff__container container">
        <div class="meta-diff__grid">
          <header class="section-header">
            <h2 class="eyebrow">Cómo se diferencia</h2>
            <p class="h2">Estrategia visual nativa.</p>
            <p class="section-header__desc">No solo prendemos anuncios. Creamos piezas gráficas que resuenan con la cultura latina para generar confianza inmediata.</p>
          </header>

          <div class="meta-diff__compare">
            <div class="meta-diff__col">
              <h3 class="eyebrow" style="color: var(--color-text-muted)">Gestión normal</h3>
              <ul class="meta-diff__list meta-diff__list--bad">
                <li>Boost post sin segmentación</li>
                <li>Sin diseño de gráficas</li>
                <li>Sin pruebas A/B de mensajes</li>
                <li>Solo buscan "Likes" de vanidad</li>
                <li>Sin integración con CRM</li>
              </ul>
            </div>
            <div class="meta-diff__col">
              <h3 class="eyebrow">Life Focus — Resultados</h3>
              <ul class="meta-diff__list meta-diff__list--good">
                <li>Segmentación cultural precisa</li>
                <li>Diseño gráfico incluido</li>
                <li>Test A/B constante de copy</li>
                <li>Enfoque total en Leads / ROAS</li>
                <li>Estrategia visual completa</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Por qué funciona -->
    <section class="meta-why section">
      <div class="meta-why__container container">
        <div class="meta-why__grid">
          <header class="section-header">
            <h2 class="eyebrow">Por qué funciona</h2>
            <p class="h2">El mercado latino en USA es específico. Tu publicidad también debe serlo.</p>
            <p class="section-header__desc">Entendemos cómo piensa, busca y compra el cliente latino en Estados Unidos. Eso hace la diferencia.</p>
          </header>
          <ul class="meta-why__list">
            {[
              [
                `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
                'Audiencias que conocemos',
                'Años de experiencia segmentando el público latino en USA. Sabemos qué funciona y qué no.'
              ],
              [
                `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`,
                'Creativos nativos',
                'Gráficas y mensajes que resuenan con la cultura y valores de tu audiencia. No adaptaciones mediocres.'
              ],
              [
                `<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>`,
                'Test y aprende constante',
                'Cada mes probamos nuevas variantes de audiencias, creativos y mensajes para mejorar resultados.'
              ],
            ].map(([iconPath, title, body]) => (
              <li class="meta-why__item">
                <div class="meta-why__icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={iconPath}></svg>
                </div>
                <div>
                  <strong>{title}</strong>
                  <p>{body}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Precio -->
    <section class="meta-price section section--alt">
      <div class="meta-price__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Inversión</h2>
          <p class="h2">Precio mensual, todo incluido.</p>
        </header>

        <div class="meta-price__card card">
          <div class="meta-price__cols">
            <div class="meta-price__info">
              <p class="eyebrow" style="margin-block-end: 0.75rem">Meta Ads — Facebook + Instagram</p>
              <div class="meta-price__price-wrap">
                <span class="meta-price__from">desde</span>
                <span class="meta-price__amount">$490</span>
                <span class="meta-price__currency">USD/mes</span>
              </div>
              <p class="meta-price__desc">Incluye gestión y diseño de creativos. Presupuesto de pauta por separado.</p>
            </div>

            <ul class="meta-price__list">
              {[
                'Estrategia de audiencias latina',
                'Diseño de piezas gráficas',
                'Copywriting persuasivo',
                'Pruebas A/B de anuncios',
                'Optimización semanal',
                'Reporte mensual en español',
              ].map(f => <li>✓ {f}</li>)}
            </ul>
          </div>
          <div class="meta-price__footer">
            <a class="btn btn--primary" href="/contacto">
              Comenzar con Meta Ads →
            </a>
          </div>
        </div>
      </div>
    </section>

    <Testimonials />
    <Faq />
    <CtaBanner
      title="¿Listo para llegar a tus clientes ideales?"
      subtitle="Cuéntanos de tu negocio y te mostramos cómo segmentar exactamente a tu público objetivo."
      ctaText="Hablar con un experto"
    />
  </main>
</BaseLayout>

<style>
  .meta-includes__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .meta-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
    @container (inline-size < 52rem) { grid-template-columns: repeat(2, 1fr); }
    @container (inline-size < 32rem) { grid-template-columns: 1fr; }
  }
  .meta-item { display: flex; gap: 1rem; align-items: flex-start; }
  .svc-icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 3rem; block-size: 3rem; flex-shrink: 0;
    border-radius: var(--radius-m); background: rgba(56,178,240,0.08);
    border: 1px solid rgba(56,178,240,0.2); color: var(--color-primary);
  }
  [data-theme="light"] .svc-icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .svc-body { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .meta-diff__container { :has(> &) { container-type: inline-size; } }
  .meta-diff__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .meta-diff__compare {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    @container (inline-size < 30rem) { grid-template-columns: 1fr; }
  }
  .meta-diff__col { display: flex; flex-direction: column; gap: 1rem; }
  .meta-diff__list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .meta-diff__list li {
    font-size: var(--font-size-small); color: var(--color-text-muted);
    padding-inline-start: 1.5rem; position: relative;
    &::before { content: '×'; position: absolute; inset-inline-start: 0; color: #ef4444; font-weight: bold; }
  }
  .meta-diff__list--good li {
    color: var(--color-text);
    &::before { content: '✓'; color: var(--color-secondary); }
  }

  .meta-why__container { :has(> &) { container-type: inline-size; } }
  .meta-why__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .meta-why__list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
  .meta-why__item { display: flex; gap: 1rem; align-items: flex-start; }
  .meta-why__icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 2.5rem; block-size: 2.5rem; flex-shrink: 0;
    border-radius: var(--radius-m);
    background: rgba(56,178,240,0.08); border: 1px solid rgba(56,178,240,0.2);
    color: var(--color-primary);
  }
  [data-theme="light"] .meta-why__icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .meta-why__item strong { display: block; font-weight: var(--font-weight-heading); color: var(--color-heading); font-size: var(--font-size-body); margin-block-end: 0.25rem; }
  .meta-why__item p { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .meta-price__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .meta-price__card { max-inline-size: 56rem; margin-inline: auto; container-type: inline-size; padding: 3rem; }
  .meta-price__cols {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;
    @container (inline-size < 34rem) { grid-template-columns: 1fr; gap: 2rem; }
  }
  .meta-price__footer { margin-block-start: 2.5rem; text-align: center; }
  .meta-price__info { display: flex; flex-direction: column; }
  .meta-price__price-wrap { display: flex; align-items: baseline; gap: 0.5rem; padding-block: 1rem; border-block: 1px solid var(--color-border); margin-block: 1rem; }
  .meta-price__amount { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: var(--font-weight-heading); color: var(--color-heading); line-height: 1; }
  .meta-price__from { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .meta-price__currency { font-size: 1rem; color: var(--color-text-muted); font-weight: 300; }
  .meta-price__desc { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.5; }
  .meta-price__list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; font-size: var(--font-size-small); color: var(--color-text); }
</style>
