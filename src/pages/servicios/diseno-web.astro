---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Faq from '../../components/sections/Faq.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import type { PageMeta } from '../../types/cms';

const meta: PageMeta = {
  title: 'Diseño Web Premium | Life Focus Agency — Sitios a Medida desde $4,000',
  description: 'Sitios web corporativos a medida para negocios latinos en USA. WordPress o Astro. HTML semántico, SEO técnico, Core Web Vitals. Desde $4,000 USD, propiedad total.',
  lang: 'es',
};

const includes = [
  { icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`, title: 'Diseño 100% a medida', body: 'Sin plantillas genéricas. Tu sitio refleja exactamente tu marca y propuesta de valor única.' },
  { icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`, title: 'Performance técnica', body: 'Core Web Vitals optimizados, HTML semántico, carga rápida desde el primer acceso global.' },
  { icon: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`, title: 'SEO técnico integrado', body: 'Arquitectura de URLs, headings, schema markup, meta tags y velocidad desde el día uno.' },
  { icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`, title: 'Páginas completas', body: 'Home, nosotros, servicios, casos de éxito, blog, contacto. Todo lo que tu negocio necesita.' },
  { icon: `<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>`, title: 'Integraciones a medida', body: 'CRM, formularios, tracking, Google Analytics, mapas, chat y más según tu negocio.' },
  { icon: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`, title: 'Propiedad total', body: 'El sitio es tuyo desde el primer día. Sin dependencias ni contratos de por vida.' },
];
---

<BaseLayout meta={meta} currentPage="/servicios">
  <main id="main-content">
    <PageHero
      eyebrow="Diseño Web Premium para Negocios Latinos en USA"
      headline="Un sitio que convierte visitas en clientes, no solo en vistas."
      description="Proyectos web corporativos a medida, con propiedad total desde el día uno. No hay plantillas: tu sitio es único, con arquitectura SEO y diseño orientado a conversión."
      breadcrumb="Servicios / Diseño Web"
    />

    <!-- Qué incluye -->
    <section class="dw-includes section">
      <div class="dw-includes__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Qué incluye el Diseño Web Premium</h2>
          <p class="h2">Tu sitio. Tu marca. Tu propiedad.</p>
          <p class="section-header__desc">Un proyecto web corporativo completo, diseñado a medida con los más altos estándares técnicos del mercado.</p>
        </header>

        <div class="dw-includes__grid">
          {includes.map(item => (
            <div class="dw-includes__item card">
              <div class="dw-includes__icon" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
              </div>
              <div>
                <h3 class="eyebrow" style="margin-block-end: 0.35rem">{item.title}</h3>
                <p class="dw-item-body">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cómo se diferencia -->
    <section class="dw-diff section section--alt">
      <div class="dw-diff__container container">
        <div class="dw-diff__grid">
          <header class="section-header">
            <h2 class="eyebrow">Cómo se diferencia</h2>
            <p class="h2">No es como los demás sitios web.</p>
            <p class="section-header__desc">La mayoría de las agencias usan plantillas que te hacen ver como uno más. Nosotros diseñamos para tu marca única.</p>
          </header>

          <div class="dw-diff__compare">
            <div class="dw-diff__col">
              <h3 class="eyebrow" style="color: var(--color-text-muted)">Un sitio web normal</h3>
              <ul class="dw-diff__list dw-diff__list--bad">
                <li>Plantillas genéricas y pesadas</li>
                <li>Código sucio que Google castiga</li>
                <li>Sin propiedad total del código</li>
                <li>Cargan lento por exceso de plugins</li>
                <li>SEO como un "extra" opcional</li>
              </ul>
            </div>
            <div class="dw-diff__col">
              <h3 class="eyebrow">Life Focus — Premium</h3>
              <ul class="dw-diff__list dw-diff__list--good">
                <li>Diseño 100% a medida desde cero</li>
                <li>Performance Core Web Vitals optimizado</li>
                <li>Propiedad total desde el día 1</li>
                <li>Código limpio y carga ultra rápida</li>
                <li>SEO técnico integrado en la base</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Precio único -->
    <section class="dw-pricing section">
      <div class="dw-pricing__container container">
        <header class="section-header section-header--centered">
          <h2 class="eyebrow">Inversión</h2>
          <p class="h2">Un proyecto, un precio claro.</p>
        </header>

        <div class="dw-pricing__card card">
          <div class="dw-pricing__cols">
            <div class="dw-pricing__info">
              <p class="eyebrow" style="margin-block-end: 0.5rem">Diseño Web Corporativo</p>
              <div class="dw-pricing__price-wrap">
                <span class="dw-pricing__from">desde</span>
                <span class="dw-pricing__amount">$4,000</span>
                <span class="dw-pricing__currency">USD</span>
              </div>
              <p class="dw-pricing__desc">
                Inversión única para un activo digital de alta gama. El precio final depende de la complejidad y alcance.
              </p>
            </div>

            <ul class="dw-pricing__list">
              {[
                'Diseño 100% único (Sin plantillas)',
                'SEO técnico + Schema Markup',
                'Performance nivel Enterprise',
                'Páginas completas a medida',
                'Integraciones CRM y Chat',
                'Soporte post-lanzamiento',
              ].map(f => <li>✓ {f}</li>)}
            </ul>
          </div>

          <div class="dw-pricing__footer">
            <a class="btn btn--primary" href="/contacto">
              Solicitar propuesta sin costo →
            </a>
          </div>
        </div>
      </div>
    </section>

    <Testimonials />
    <Faq />
    <CtaBanner
      title="¿Tienes un proyecto en mente?"
      subtitle="Cuéntanos de tu negocio y te enviamos una propuesta personalizada sin costo dentro de las 24 horas."
      ctaText="Solicitar propuesta"
    />
  </main>
</BaseLayout>

<style>
  .dw-includes__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .dw-includes__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    @container (inline-size < 52rem) { grid-template-columns: repeat(2, 1fr); }
    @container (inline-size < 32rem) { grid-template-columns: 1fr; }
  }
  .dw-includes__item { display: flex; gap: 1rem; align-items: flex-start; }
  .dw-includes__icon {
    display: inline-flex; align-items: center; justify-content: center;
    inline-size: 3rem; block-size: 3rem; flex-shrink: 0;
    border-radius: var(--radius-m);
    background: rgba(56,178,240,0.08); border: 1px solid rgba(56,178,240,0.2);
    color: var(--color-primary);
  }
  [data-theme="light"] .dw-includes__icon { background: rgba(56,178,240,0.1); border-color: rgba(56,178,240,0.25); }
  .dw-item-body { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; }

  .dw-diff__container { :has(> &) { container-type: inline-size; } }
  .dw-diff__grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: var(--spacing-space-xl); align-items: start;
    @container (inline-size < 48rem) { grid-template-columns: 1fr; }
  }
  .dw-diff__compare {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
    @container (inline-size < 30rem) { grid-template-columns: 1fr; }
  }
  .dw-diff__col { display: flex; flex-direction: column; gap: 1rem; }
  .dw-diff__list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .dw-diff__list li {
    font-size: var(--font-size-small); color: var(--color-text-muted);
    padding-inline-start: 1.5rem; position: relative;
    &::before { content: '×'; position: absolute; inset-inline-start: 0; color: #ef4444; font-weight: bold; }
  }
  .dw-diff__list--good li {
    color: var(--color-text);
    &::before { content: '✓'; color: var(--color-secondary); }
  }

  .dw-pricing__container { :has(> &) { container-type: inline-size; } display: flex; flex-direction: column; gap: var(--spacing-space-xl); }
  .dw-pricing__card { max-inline-size: 56rem; margin-inline: auto; container-type: inline-size; padding: 3rem; }
  .dw-pricing__cols {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;
    @container (inline-size < 34rem) { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  .dw-pricing__footer { margin-block-start: 2.5rem; text-align: center; }
  .dw-pricing__info { display: flex; flex-direction: column; }
  .dw-pricing__price-wrap { display: flex; align-items: baseline; gap: 0.5rem; padding-block: 1rem; border-block: 1px solid var(--color-border); margin-block: 1rem; }
  .dw-pricing__amount { font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: var(--font-weight-heading); color: var(--color-heading); line-height: 1; }
  .dw-pricing__from { font-size: var(--font-size-small); color: var(--color-text-muted); }
  .dw-pricing__currency { font-size: 1rem; color: var(--color-text-muted); font-weight: 300; }
  .dw-pricing__desc { font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.6; }
  .dw-pricing__list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; font-size: var(--font-size-small); color: var(--color-text); }
</style>
