---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import type { PageMeta } from '../types/cms';

const meta: PageMeta = {
  title: 'Contacto | Life Focus Agency — Agenda tu Videollamada Gratuita',
  description: 'Agenda una videollamada gratuita de 30 minutos con Life Focus. Sin compromiso. Solo claridad. Para negocios latinos en USA.',
  lang: 'es',
};
---

<BaseLayout meta={meta} currentPage="/contacto">
  <main id="main-content">
    <PageHero
      eyebrow="Contacto — Agenda tu Diagnóstico Gratuito"
      headline="¿Listo para comenzar a crecer? Hablemos."
      description="Agenda una videollamada de 30 minutos, completamente gratuita. Sin compromiso. Solo claridad sobre qué necesita tu negocio."
      breadcrumb="Contacto"
    />

    <section class="contact section">
      <div class="contact__container container">
        <div class="contact__grid">
          <!-- Formulario -->
          <div class="contact__form-wrap">
            <form class="contact__form" name="contacto" method="POST" data-netlify="true" novalidate>
              <h2 class="eyebrow" style="margin-block-end: 0.5rem">Escríbenos</h2>
              <p class="h3" style="margin-block-end: 1.5rem">Cuéntanos de tu negocio</p>

              <div class="contact__form-grid">
                <div class="form-field">
                  <label class="form-label" for="nombre">Tu nombre</label>
                  <input class="form-input" type="text" id="nombre" name="nombre" placeholder="Daniel Aldea" required autocomplete="name" />
                </div>

                <div class="form-field">
                  <label class="form-label" for="empresa">Nombre del negocio</label>
                  <input class="form-input" type="text" id="empresa" name="empresa" placeholder="Mi Clínica Dental" autocomplete="organization" />
                </div>

                <div class="form-field">
                  <label class="form-label" for="email">Correo electrónico</label>
                  <input class="form-input" type="email" id="email" name="email" placeholder="hola@minegocio.com" required autocomplete="email" />
                </div>

                <div class="form-field">
                  <label class="form-label" for="telefono">WhatsApp / Teléfono</label>
                  <input class="form-input" type="tel" id="telefono" name="telefono" placeholder="+1 (555) 000-0000" autocomplete="tel" />
                </div>

                <div class="form-field contact__form-field--full">
                  <label class="form-label" for="servicio">¿Qué servicio te interesa?</label>
                  <select class="form-input" id="servicio" name="servicio">
                    <option value="">Selecciona una opción…</option>
                    <option value="waas">WaaS — Web as a Service</option>
                    <option value="diseno-web">Diseño Web Premium</option>
                    <option value="google-ads">Google Ads</option>
                    <option value="meta-ads">Meta Ads</option>
                    <option value="redes-sociales">Redes Sociales</option>
                    <option value="otro">Otro / No sé todavía</option>
                  </select>
                </div>

                <div class="form-field contact__form-field--full">
                  <label class="form-label" for="mensaje">Cuéntanos del desafío o pregunta que tienes</label>
                  <textarea
                    class="form-input"
                    id="mensaje"
                    name="mensaje"
                    placeholder="Tengo una clínica dental en Miami y quiero llegar a más pacientes…"
                    rows="4"
                  ></textarea>
                </div>
              </div>

              <button class="btn btn--primary" type="submit" style="inline-size: 100%; justify-content: center; margin-block-start: 1rem;">
                Enviar mensaje
              </button>
              <p class="contact__form-disclaimer">
                Al enviar este formulario, aceptas que nos pongamos en contacto contigo en las próximas 24 horas hábiles.
              </p>
            </form>
          </div>

          <!-- Info lateral -->
          <aside class="contact__info">
            <div class="card contact__info-card">
              <h2 class="eyebrow" style="margin-block-end: 0.5rem">Agenda directamente</h2>
              <p class="h3" style="margin-block-end: 1rem">Videollamada gratuita de 30 min</p>
              <p style="font-size: var(--font-size-small); color: var(--color-text-muted); line-height: 1.65; margin-block-end: 1.25rem;">
                Prefiere hablar directamente? Elige el horario que más te convenga. La llamada es totalmente gratuita y sin compromiso.
              </p>
              <a class="btn btn--primary" href="#" style="inline-size:100%;justify-content:center">
                Ver horarios disponibles
              </a>
            </div>

            <div class="card contact__info-card">
              <h3 class="eyebrow">Contacto directo</h3>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:0.75rem;margin-block-start:0.75rem;">
                <li style="display:flex;gap:0.6rem;align-items:center;font-size:var(--font-size-small);">
                  <span>📧</span>
                  <a href="mailto:hola@lifefocus.agency" style="color:var(--color-primary)">hola@lifefocus.agency</a>
                </li>
                <li style="display:flex;gap:0.6rem;align-items:center;font-size:var(--font-size-small);color:var(--color-text-muted);">
                  <span>⏱️</span>
                  Respondemos en menos de 24 horas hábiles
                </li>
              </ul>
            </div>

            <div class="contact__trust">
              <p class="eyebrow" style="margin-block-end:0.75rem">¿Por qué confiar en nosotros?</p>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;">
                {['+400 clientes en USA y Latinoamérica', '+25 años de experiencia en marketing digital', 'Resultados garantizados en 90 días', 'Reportes transparentes cada mes'].map(item => (
                  <li style="font-size:var(--font-size-small);color:var(--color-text-muted);display:flex;gap:0.5rem;align-items:flex-start;">
                    <span style="color:var(--color-secondary);flex-shrink:0">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact__container { :has(> &) { container-type: inline-size; } }
  .contact__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--spacing-space-xl);
    align-items: start;
    @container (inline-size < 50rem) { grid-template-columns: 1fr; }
  }
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2.5rem;
  }
  .contact__form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    @container (inline-size < 36rem) { grid-template-columns: 1fr; }
  }
  .contact__form-field--full { grid-column: span 2; @container (inline-size < 36rem) { grid-column: span 1; } }
  .contact__form-disclaimer {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-block-start: 0.75rem;
    line-height: 1.5;
  }

  .contact__info { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact__info-card { padding: 1.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .contact__trust { padding: 1.5rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-l); }
</style>
