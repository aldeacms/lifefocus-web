---
// contacto.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
    title="Contacto | Life Focus"
    description="Agenda una llamada estratégica hoy mismo."
>
    <Header slot="header" />

    <section class="c-section c-contact">
        <div class="o-container c-contact__container">
            <div class="c-contact__content">
                <span class="c-eyebrow">Agendemos</span>
                <h1 class="h2">Hablemos de tu próximo gran salto digital.</h1>
                <p class="text-l">
                    Rellena el formulario y nos pondremos en contacto contigo en
                    menos de 24 horas.
                </p>

                <div class="c-contact__info">
                    <div class="c-contact__info-item">
                        <strong>Email:</strong>
                        <span>hola@lifefocus.waas</span>
                    </div>
                    <div class="c-contact__info-item">
                        <strong>Ubicación:</strong>
                        <span>Miami, FL & Santiago, CL</span>
                    </div>
                </div>
            </div>

            <form class="c-form">
                <div class="c-form__group">
                    <label for="name" class="c-form__label"
                        >Nombre Completo</label
                    >
                    <input
                        type="text"
                        id="name"
                        name="name"
                        class="c-form__input"
                        placeholder="Ej. Juan Pérez"
                        required
                    />
                </div>
                <div class="c-form__group">
                    <label for="email" class="c-form__label"
                        >Email Corporativo</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        class="c-form__input"
                        placeholder="juan@empresa.com"
                        required
                    />
                </div>
                <div class="c-form__group">
                    <label for="message" class="c-form__label"
                        >¿Cómo podemos ayudarte?</label
                    >
                    <textarea
                        id="message"
                        name="message"
                        class="c-form__input"
                        rows="4"
                        placeholder="Cuéntanos sobre tu negocio..."></textarea>
                </div>
                <button type="submit" class="c-button" data-variant="primary"
                    >Enviar Mensaje</button
                >
            </form>
        </div>
    </section>

    <Footer slot="footer" />
</BaseLayout>

<style>
    .c-contact {
        padding-block: var(--space-xxl);
        min-height: 80vh;
        display: flex;
        align-items: center;
    }

    .c-contact__container {
        display: grid;
        grid-template-columns: repeat(
            auto-fit,
            minmax(mi(min(100%, 400px)), 1fr)
        );
        gap: var(--space-xxl);
        align-items: center;
    }

    .c-contact__content {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
    }

    .c-contact__info {
        margin-block-start: var(--space-l);
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
    }

    .c-form {
        background-color: var(--color-surface);
        padding: var(--space-xl);
        border-radius: var(--radius-l);
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
    }

    .c-form__group {
        display: flex;
        flex-direction: column;
        gap: var(--space-xxs);
    }

    .c-form__label {
        font-size: var(--text-xs);
        font-weight: var(--weight-bold);
        color: var(--color-text-heading);
    }

    .c-form__input {
        padding: var(--space-s);
        background-color: var(--color-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-s);
        color: var(--color-text);
        font-family: inherit;
        transition: border-color var(--transition-fast);
    }

    .c-form__input:focus {
        outline: none;
        border-color: var(--primary);
    }
</style>
