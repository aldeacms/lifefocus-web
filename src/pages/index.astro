---
// index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="LifeFocus | Desarrollo Web de Alto Valor"
  description="Diseño estratégico y desarrollo web de alto rendimiento para proyectos que buscan escalar y liberar tiempo."
>
  <Header slot="header" />

  <!-- Hero Section -->
  <Hero
    eyebrow="Propósito y Eficiencia"
    title="Sistemas Web que Trabajan para Ti."
    description="Bienvenido a LifeFocus. Construimos plataformas digitales de alto impacto siguiendo los estándares Era 4, optimizadas para conversión y mantenibilidad."
    primaryCta="Ver Proyectos"
    secondaryCta="Agendar Consulta"
  />

  <!-- Componente Demo Genérico: Feature Grid -->
  <section class="c-section" id="metodologia">
    <div class="o-container">
      <div class="o-grid" data-columns="3">
        <article class="c-card">
          <h2 class="h3 c-card__title">HTML Semántico</h2>
          <p class="c-card__desc">
            Landmarks y etiquetas consistentes para accesibilidad y rastreo de
            Google.
          </p>
        </article>

        <article class="c-card">
          <h2 class="h3 c-card__title">Componentes BEM</h2>
          <p class="c-card__desc">
            Uso estricto de Clases BEM. Cero "Class Soup" o abuso de Tailwind en
            el DOM.
          </p>
        </article>

        <article class="c-card">
          <h2 class="h3 c-card__title">Responsive Fluido</h2>
          <p class="c-card__desc">
            Soporte total para Container Queries y escalas tipográficas de
            fluido nativo.
          </p>
        </article>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Estilos solo demostrativos para The Kitchen Sink */
  .c-section {
    padding-block: var(--section-space);
    container-type: inline-size;
  }

  .o-grid {
    display: grid;
    gap: var(--space-m);
  }

  .o-grid[data-columns="3"] {
    grid-template-columns: repeat(auto-fit, minmax(mi(min(100%, 300px)), 1fr));
  }

  .c-card {
    background-color: var(--surface-2);
    padding: var(--space-l);
    border-radius: var(--radius-m);
    border: 1px solid var(--border-color);
  }

  .c-card__title {
    color: var(--heading-color);
    margin-block-end: var(--space-xs);
  }

  .c-card__desc {
    color: var(--text-color);
    margin: 0;
  }
</style>
