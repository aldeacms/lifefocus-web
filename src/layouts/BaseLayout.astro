---
import type { PageMeta } from '../types/cms';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  meta: PageMeta;
  currentPage?: string;
}

const { meta, currentPage } = Astro.props;
const lang = meta.lang ?? 'es';
const canonicalUrl = meta.canonicalUrl ?? Astro.url.href;
const ogType = meta.ogType ?? 'website';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Fonts: Barlow -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- SEO Principal -->
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={canonicalUrl} />
    {meta.ogImage && <meta property="og:image" content={meta.ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    {meta.ogImage && <meta name="twitter:image" content={meta.ogImage} />}

    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#38B2F0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <!-- Cursor personalizado (solo en pointer: fine) -->
    <div class="cursor-glow" id="cursor-glow" aria-hidden="true"></div>
    <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>
    <div class="cursor-dot" id="cursor-dot" aria-hidden="true"></div>

    <Header currentPage={currentPage} />
    <slot />
    <Footer />
  </body>
</html>

<script>
  // ── Cursor personalizado ──
  const dot  = document.getElementById('cursor-dot');
  const ring = document.getElementById('cursor-ring');
  const root = document.documentElement;

  let rx = window.innerWidth / 2, ry = window.innerHeight / 2;
  let dx = rx, dy = ry;

  window.addEventListener('mousemove', e => {
    dx = e.clientX;
    dy = e.clientY;
    // Cursor dot sigue inmediatamente
    if (dot)  { dot.style.left  = dx + 'px'; dot.style.top  = dy + 'px'; }
    // Cursor glow usa CSS var para el radial-gradient
    root.style.setProperty('--lf-cx', dx + 'px');
    root.style.setProperty('--lf-cy', dy + 'px');
  }, { passive: true });

  // Ring con lerp suave
  function animate() {
    rx += (dx - rx) * 0.12;
    ry += (dy - ry) * 0.12;
    if (ring) { ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; }
    requestAnimationFrame(animate);
  }
  animate();

  // Efecto hover en links/botones
  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => {
      if (dot)  { dot.style.width  = '14px'; dot.style.height = '14px'; }
      if (ring) { ring.style.width = '52px'; ring.style.height = '52px'; ring.style.borderColor = 'rgba(56,178,240,0.8)'; }
    });
    el.addEventListener('mouseleave', () => {
      if (dot)  { dot.style.width  = ''; dot.style.height = ''; }
      if (ring) { ring.style.width = ''; ring.style.height = ''; ring.style.borderColor = ''; }
    });
  });
</script>
